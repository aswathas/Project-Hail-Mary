  SIG --> ESQL --> FOR
  FOR --> PAT
  PAT --> EQL --> FOR
  FOR --> COR --> FOR
  FOR --> OLA
  OLA --> GEMMA
  GEMMA --> OLA
  SRV -. SSE .-> UI
  UI -. REST .-> SRV
  OLA -. JSON .-> UI


/* pattern: AP-014
   name: MEV Sandwich Attack
   confidence: 0.80
   description: Attacker front-runs victim swap, victim executes at worse price, attacker back-runs for profit
   required_signals: large_token_transfer
*/
sequence with maxspan=5m
  [derived where derived_type == "swap_summary"]
  [signal where signal_name == "large_token_transfer" or signal_name == "new_wallet_high_value"]

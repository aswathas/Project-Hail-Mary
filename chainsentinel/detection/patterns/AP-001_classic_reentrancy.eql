// pattern: AP-001
// name: classic_reentrancy
// family: reentrancy
// confidence: 0.95
// min_weight: 7
// description: Recursive call depth pattern with value drain at each depth and delayed storage update — classic single-function reentrancy
sequence by tx_hash with maxspan=5m
  [signal where signal_name == "recursive_depth_pattern"]
  [signal where signal_name == "storage_update_delay"]
  [signal where signal_name == "value_drain_per_depth"]

// pattern: AP-009
// name: amm_spot_price
// family: oracle_manipulation
// confidence: 0.90
// min_weight: 7
// description: AMM spot price manipulated via large swap, oracle reads manipulated price, reserve ratio spikes
sequence by tx_hash with maxspan=5m

-- signal: value_dispersion
-- family: value
-- severity: HIGH
-- score: 0.75
-- weight: 2
-- description: Detects fund dispersion where a single address sends to 3 or more distinct recipients
FROM forensics
| WHERE layer == "derived" AND derived_type == "value_flow_graph"
| STATS recipient_count = COUNT_DISTINCT(to_address), total_value = SUM(value_eth) BY from_address, block_number
| WHERE recipient_count >= 3
| EVAL tx_hash = from_address
| SORT total_value DESC
| LIMIT 50

-- signal: mint_to_dump_ratio
-- family: value
-- severity: CRIT
-- score: 0.90
-- weight: 3
-- description: Detects large token mints from zero address indicating potential mint-and-dump attack
FROM forensics
| WHERE layer == "derived" AND derived_type == "enriched_event_logs"
| WHERE event_name == "Transfer" AND from_address == "0x0000000000000000000000000000000000000000"
| KEEP tx_hash, block_number, to_address, contract_address, value_eth
| SORT block_number DESC
| LIMIT 50

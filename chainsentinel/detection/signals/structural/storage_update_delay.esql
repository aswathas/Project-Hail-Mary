-- signal: storage_update_delay
-- family: structural
-- severity: CRIT
-- score: 0.90
-- weight: 3
-- description: Detects state updates that occur after external calls — classic reentrancy indicator
FROM forensics
| WHERE layer == "derived" AND derived_type == "state_delta_per_tx" AND updated_between_calls == false
| STATS slot_count = COUNT(*) BY contract_address, tx_hash, block_number
| WHERE slot_count >= 1
| SORT slot_count DESC
| LIMIT 50

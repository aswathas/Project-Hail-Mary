-- signal: reentrancy_guard_bypass
-- family: additional
-- severity: CRIT
-- score: 0.90
-- weight: 3
-- description: Detects successful reentrant calls despite reentrancy guard — guard bypass via cross-function or read-only reentrancy
FROM forensics
| WHERE layer == "derived" AND derived_type == "execution_structure"
| STATS call_count = COUNT(*), max_depth = MAX(call_depth) BY callee_address, tx_hash, block_number
| WHERE call_count > 2 AND max_depth >= 3
| SORT call_count DESC
| LIMIT 50

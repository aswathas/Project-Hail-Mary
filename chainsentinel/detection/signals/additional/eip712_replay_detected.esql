-- signal: eip712_replay_detected
-- family: additional
-- severity: CRIT
-- score: 0.90
-- weight: 3
-- description: Detects duplicate EIP-712 signature hash or expired deadline in permit usage
FROM forensics
| WHERE layer == "derived" AND derived_type == "permit_usage_log"
| STATS usage_count = COUNT(*) BY signature_hash, tx_hash, block_number
| WHERE usage_count > 1
| SORT usage_count DESC
| LIMIT 50

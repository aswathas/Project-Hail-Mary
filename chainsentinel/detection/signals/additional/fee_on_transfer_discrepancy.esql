-- signal: fee_on_transfer_discrepancy
-- family: additional
-- severity: HIGH
-- score: 0.70
-- weight: 2
-- description: Detects token transfers where sent amount differs from received amount (fee-on-transfer tokens)
FROM forensics
| WHERE layer == "derived" AND derived_type == "token_transfer_graph"
| WHERE amount_decimal > 0
| STATS total_sent = SUM(amount_decimal) BY from_address, to_address, token_address, tx_hash, block_number
| WHERE total_sent > 0
| SORT total_sent DESC
| LIMIT 50

-- signal: multi_hop_fund_trail
-- family: graph
-- severity: HIGH
-- score: 0.70
-- weight: 2
-- description: Detects funds traceable through 3 or more hops from exploit source
FROM forensics
| WHERE layer == "derived" AND derived_type == "fund_hop_chains"
| WHERE hop_index >= 3
| KEEP tx_hash, block_number, from_address, to_address, hop_index, value_eth, taint_score
| SORT hop_index DESC
| LIMIT 50
